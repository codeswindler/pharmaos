# Local Docker maps MySQL to 3307 because this machine already has MariaDB on 3306.
DATABASE_URL=mysql://pharmaos:pharmaos@127.0.0.1:3307/pharmaos
PORT=5000
SERVE_WEB=true
WEB_DIST_DIR=artifacts/pharma-pos/dist/public
JWT_SECRET=change-me-in-production
MPESA_ENCRYPTION_KEY=change-me-separately-in-production
PUBLIC_API_URL=https://your-public-api.example.com
